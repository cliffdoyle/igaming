# Copy this file to ".env" on the SERVER and fill in strong values.
# The real ".env" is gitignored and must NEVER be committed.
#
#   cp .env.example .env
#   nano .env        # then change the passwords below

DB_NAME=ontariogamers
DB_USER=wp_user

# Use long random passwords for production. Generate one with:
#   openssl rand -base64 24
DB_PASSWORD=CHANGE_ME_to_a_long_random_password
DB_ROOT_PASSWORD=CHANGE_ME_to_a_different_long_random_password
